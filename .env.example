# Copy to .env and fill in. NEVER commit the real .env.
SECRET_KEY=generate-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=fitness-genius.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://fitness-genius.onrender.com
# Postgres in production (Render provides this). Omit locally to use SQLite.
DATABASE_URL=postgres://user:pass@host:5432/dbname
# S3 photo uploads (optional). boto3 reads AWS creds from the environment.
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
